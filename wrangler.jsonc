{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "toolheadscanner",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-24",
	"kv_namespaces": [
		{
			"binding": "HASH_CACHE",
			"id": "07f8e78f03684fea85ea947ad6b23bb6",
			"preview_id": "129a35253865475887680149202bec8e"
		},
		{
			"binding": "SCANNER_STATE",
			"id": "546ca9645ded430688da23023b5da8a8",
			"preview_id": "62337d9564464571bc8701afc5537781"
		}
	],
	"triggers": {
		"crons": [
			"0 8 * * *"
		]
	},
	"vars": {
